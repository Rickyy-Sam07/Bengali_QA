GROQ_API_KEY=your_groq_api_key_here
# Optional OCR settings (recommended for scanned Bengali PDFs)
# Example Tesseract command path on Windows:
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
TESSERACT_CMD=

# Point this to the folder that contains ben.traineddata (prefer tessdata_best)
# Example:
# TESSDATA_PREFIX=C:\\Program Files\\Tesseract-OCR\\tessdata_best
TESSDATA_PREFIX=
